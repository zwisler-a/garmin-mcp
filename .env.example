GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=your-garmin-password
# Optional: directory where the session tokens get cached after the first login
# GARMIN_TOKEN_STORE=~/.garminconnect

# Optional: set to see garminconnect's internal debug logging (which login
# strategy it's trying, HTTP responses, etc). Goes to stderr by default, or to
# GARMIN_DEBUG_LOG if set (since stdout is reserved for the MCP protocol).
# GARMIN_DEBUG=1
# GARMIN_DEBUG_LOG=/tmp/garmin_debug.log
